APP_NAME="BorderReach"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://border.example.gov
APP_FORCE_HTTPS=true

# Used by Android setup QR codes. Use the same public domain or a phone-reachable LAN URL during pilots.
MOBILE_SETUP_HOST=https://border.example.gov
MOBILE_DEFAULT_COUNTRY_CODE=SLE

# Lock Laravel host handling to the public domain. Use comma-separated hosts when needed.
TRUSTED_HOSTS=border.example.gov

# Set to the reverse proxy IP/CIDR in production. Use * only when the proxy layer is controlled.
TRUSTED_PROXIES=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=cache
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=borderreach
DB_USERNAME=borderreach
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_PATH=/
SESSION_DOMAIN=null

# Mobile officers may work offline for long periods; 43200 minutes is 30 days.
SANCTUM_EXPIRATION=43200
SANCTUM_STATEFUL_DOMAINS=border.example.gov

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=borderreach

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.example.gov
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@border.example.gov"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
